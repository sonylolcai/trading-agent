# PA Agent Backend Dockerfile
# FastAPI server on port 8000

FROM python:3.11-slim-bookworm

WORKDIR /app

# Use Aliyun mirrors for apt
RUN sed -i 's/deb.debian.org/mirrors.aliyun.com/g' /etc/apt/sources.list.d/debian.sources

# Copy dependency list and install (Tsinghua PyPI mirror)
COPY deploy/requirements-server.txt /tmp/
RUN pip install --no-cache-dir --upgrade pip -i https://pypi.tuna.tsinghua.edu.cn/simple && \
    pip install --no-cache-dir -i https://pypi.tuna.tsinghua.edu.cn/simple -r /tmp/requirements-server.txt

# Copy the entire project
COPY . .

# Ensure runtime directories exist
RUN mkdir -p config logs records/pending cache/kline trade_records

# Create default settings.json if not present
RUN python -c "from pa_agent.config.settings import load_settings; load_settings()" || true

EXPOSE 8000

CMD ["uvicorn", "pa_agent.api.app:create_app", "--host", "0.0.0.0", "--port", "8000", "--factory"]
